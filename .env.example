# ============================================================
# DATABASE CONFIGURATION (SQLite)
# ============================================================
# Standalone SQLite local file path (must start with file:)
DATABASE_URL=file:./school.db

# ============================================================
# APP CONFIGURATION
# ============================================================

# Secret key for Express cookie sessions (random string recommended)
SESSION_SECRET=local_offline_secret_key_change_me_9a8b7c

PORT=8085

# Frontend Vite dev server port
VITE_PORT=3000

# Base path for the frontend app (/ for local dev)
BASE_PATH=/

NODE_ENV=development
HTTPS=false
